{{> partials/head }}
<div id="app">
    <main>
        <h1>{{title}}</h1>
        <div class="center">
            {{#error }}
                <p class="error">{{error}}</p>
            {{/error}}
            <form method="post">
                <label class="body-medium" for="name">Name</label>
                <input id="name" type="text" name="name" value="{{ budget.name }}"/>
                <label class="body-medium" for="description">Description</label>
                <textarea id="description" name="description">{{ budget.description }}</textarea>
                <input id="submit" type="submit" class="button button-primary" value="Save"/>
            </form>
        </div>
    </main>
</div>
{{>partials/foot}}
